{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ],
  "env": {
    "ELEVENLABS_API_KEY": "@elevenlabs_api_key",
    "ELEVENLABS_VOICE_ID": "@elevenlabs_voice_id",
    "OPENCLAW_GATEWAY_TOKEN": "@openclaw_gateway_token",
    "OPENCLAW_API_URL": "@openclaw_api_url"
  }
}
